# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Criptografia de dados sensíveis (AES-256 via pgcrypto)
DB_ENCRYPTION_KEY=your-32-char-minimum-encryption-key

# Auth
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Strava OAuth
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:3000/auth/callback/strava
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# TrainingPeaks OAuth
TP_CLIENT_ID=your-tp-client-id
TP_CLIENT_SECRET=your-tp-client-secret
TP_REDIRECT_URI=http://localhost:3000/auth/callback/trainingpeaks

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_AI_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@fitcoachai.com

# Monitoring
SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# Push Notifications (VAPID)
# Generate: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIV:', v.private_key); print('PUB:', v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:noreply@fitcoachai.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # R$149/mo — até 5 atletas
STRIPE_PRICE_PRO=price_...       # R$299/mo — até 20 atletas
STRIPE_PRICE_ELITE=price_...     # R$499/mo — ilimitado

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
